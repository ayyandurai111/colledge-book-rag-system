# Copy this file to .env and fill in your values.
# (.env is in .gitignore — it will never be committed.)
#
# This is a pure-retrieval RAG system — no LLM API key is required.

# Embedding model (multilingual — supports both Tamil and English)
COLLEGE_RAG_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Semantic chunking parameters
COLLEGE_RAG_MIN_CHUNK_CHARS=200
COLLEGE_RAG_MAX_CHUNK_CHARS=1200
COLLEGE_RAG_BREAKPOINT_PERCENTILE=75

# Retrieval
COLLEGE_RAG_TOP_K=5

# Python-API-only: sentence-level SearchResult.highlight (not shown by the UI)
COLLEGE_RAG_HIGHLIGHT_SENTENCES=2
